generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STORE_MANAGER
  SALES_PERSON
}

enum InventoryTransactionType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  SALE
  RETURN
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
  OTHER
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
  REFUNDED
}

enum NotificationType {
  LOW_STOCK
  NEW_SALE
  STOCK_MOVEMENT
  SYSTEM
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  role         Role     @default(SALES_PERSON)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens        RefreshToken[]
  productsCreated      Product[]              @relation("ProductCreatedBy")
  salesCreated         Sale[]                 @relation("SaleCreatedBy")
  inventoryCreated     InventoryTransaction[] @relation("InventoryCreatedBy")
  notifications        Notification[]
  supplierHistoryItems SupplierProductHistory[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products              Product[]
  inventoryTransactions InventoryTransaction[]
  productHistory        SupplierProductHistory[]
}

model Product {
  id                String   @id @default(uuid())
  categoryId        String
  supplierId        String?
  name              String
  sku               String   @unique
  barcode           String?  @unique
  brand             String?
  modelNumber       String?
  description       String?
  imageUrl          String?
  costPrice         Decimal  @default(0) @db.Decimal(12, 2)
  sellingPrice      Decimal  @db.Decimal(12, 2)
  quantityOnHand    Int      @default(0)
  lowStockThreshold Int      @default(5)
  isActive          Boolean  @default(true)
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category              Category                 @relation(fields: [categoryId], references: [id])
  supplier              Supplier?                @relation(fields: [supplierId], references: [id])
  createdBy             User?                    @relation("ProductCreatedBy", fields: [createdById], references: [id])
  saleItems             SaleItem[]
  inventoryTransactions InventoryTransaction[]
  notifications         Notification[]
  supplierHistory       SupplierProductHistory[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([name])
}

model SupplierProductHistory {
  id          String   @id @default(uuid())
  supplierId  String
  productId   String
  unitCost    Decimal  @db.Decimal(12, 2)
  quantity    Int
  suppliedAt  DateTime @default(now())
  createdById String?

  supplier  Supplier @relation(fields: [supplierId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  createdBy User?    @relation(fields: [createdById], references: [id])

  @@index([supplierId])
  @@index([productId])
}

model Sale {
  id             String        @id @default(uuid())
  saleNumber     String        @unique
  customerName   String?
  customerPhone  String?
  status         SaleStatus    @default(COMPLETED)
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod  PaymentMethod @default(CASH)
  notes          String?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  createdBy             User                   @relation("SaleCreatedBy", fields: [createdById], references: [id])
  items                 SaleItem[]
  inventoryTransactions InventoryTransaction[]

  @@index([createdAt])
  @@index([createdById])
}

model SaleItem {
  id             String  @id @default(uuid())
  saleId         String
  productId      String
  quantity       Int
  unitPrice      Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model InventoryTransaction {
  id              String                   @id @default(uuid())
  productId       String
  transactionType InventoryTransactionType
  quantity        Int
  quantityBefore  Int
  quantityAfter   Int
  unitCost        Decimal?                 @db.Decimal(12, 2)
  reference       String?
  reason          String?
  saleId          String?
  supplierId      String?
  createdById     String
  createdAt       DateTime                 @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  sale      Sale?     @relation(fields: [saleId], references: [id])
  supplier  Supplier? @relation(fields: [supplierId], references: [id])
  createdBy User     @relation("InventoryCreatedBy", fields: [createdById], references: [id])

  @@index([productId])
  @@index([createdAt])
}

model Notification {
  id               String           @id @default(uuid())
  recipientId      String?
  notificationType NotificationType
  title            String
  message          String
  productId        String?
  isRead           Boolean          @default(false)
  createdAt        DateTime         @default(now())
  readAt           DateTime?

  recipient User?    @relation(fields: [recipientId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])

  @@index([recipientId])
  @@index([isRead])
}
