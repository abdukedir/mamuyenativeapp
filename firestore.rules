rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isBootstrapSuperAdmin() {
      return signedIn()
        && (
          !exists(/databases/$(database)/documents/users/$(request.auth.uid))
          || request.auth.token.role in ['admin', 'member']
          || request.auth.token.superadmin == true
        );
    }

    function isActiveUser() {
      return signedIn()
        && (
          isBootstrapSuperAdmin()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && userDoc(request.auth.uid).data.isActive != false
          )
        );
    }

    function isAdmin() {
      return isActiveUser();
    }

    function hasMemberAccess() {
      return isActiveUser()
        && (
          userDoc(request.auth.uid).data.role == 'member'
          || userDoc(request.auth.uid).data.role == 'admin'
          || userDoc(request.auth.uid).data.role == 'membe'
        );
    }

    function allowedSelfCreate(uid) {
      return isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.username is string
        && request.resource.data.usernameLower is string
        && request.resource.data.username == request.resource.data.usernameLower
        && request.resource.data.role in ['admin', 'member', 'manager', 'salesperson']
        && request.resource.data.isVerified is bool
        && request.resource.data.isActive == true
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'username',
          'usernameLower',
          'fullName',
          'phone',
          'role',
          'profileImage',
          'isVerified',
          'isActive',
          'createdAt',
          'updatedAt'
        ]);
    }

    function allowedSelfUpdate(uid) {
      return isOwner(uid)
        && resource.data.role == request.resource.data.role
        && resource.data.isActive == request.resource.data.isActive
        && request.resource.data.uid == uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.username == resource.data.username
        && request.resource.data.usernameLower == resource.data.usernameLower
        && (
          request.resource.data.isVerified == resource.data.isVerified
          || (request.auth.token.email_verified == true && request.resource.data.isVerified == true)
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'fullName',
          'phone',
          'profileImage',
          'isVerified',
          'pushTokens',
          'notificationSettings',
          'updatedAt'
        ]);
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || hasMemberAccess();
      allow create: if allowedSelfCreate(uid) || hasMemberAccess();
      allow update: if allowedSelfUpdate(uid) || hasMemberAccess();
      allow delete: if hasMemberAccess();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.username == username
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'username',
          'createdAt'
        ]);
      allow update: if false;
      allow delete: if hasMemberAccess();
    }

    function hasRole(role) {
      return isActiveUser();
    }

    function canManageProducts() {
      return isActiveUser();
    }

    function allowedCategoryCreate() {
      return canManageProducts()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.accent is string
        && request.resource.data.keys().hasOnly([
          'name',
          'accent',
          'createdBy',
          'createdAt',
          'updatedAt'
        ]);
    }

    match /categories/{categoryId} {
      allow read: if isActiveUser();
      allow create: if allowedCategoryCreate();
      allow update, delete: if isActiveUser();
    }

    function allowedProductCreate() {
      return canManageProducts()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerName == userDoc(request.auth.uid).data.fullName
        && request.resource.data.categoryId is string
        && request.resource.data.categoryName is string
        && request.resource.data.categoryAccent is string
        && request.resource.data.barcode is string
        && request.resource.data.costPrice is number
        && request.resource.data.costPrice >= 0
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.stock is int
        && request.resource.data.stock >= 0
        && request.resource.data.minimumStockLevel is int
        && request.resource.data.minimumStockLevel >= 0
        && request.resource.data.criticalStockLevel is int
        && request.resource.data.criticalStockLevel >= 0
        && request.resource.data.isActive == true
        && request.resource.data.status == 'active'
        && request.resource.data.keys().hasOnly([
          'name',
          'sku',
          'categoryId',
          'categoryName',
          'categoryAccent',
          'barcode',
          'costPrice',
          'price',
          'stock',
          'minimumStockLevel',
          'criticalStockLevel',
          'description',
          'ownerId',
          'ownerName',
          'isActive',
          'status',
          'createdAt',
          'updatedAt'
        ]);
    }

    function allowedProductOwnerUpdate() {
      return canManageProducts()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.ownerName == resource.data.ownerName
        && request.resource.data.categoryId is string
        && request.resource.data.categoryName is string
        && request.resource.data.categoryAccent is string
        && request.resource.data.barcode is string
        && request.resource.data.costPrice is number
        && request.resource.data.costPrice >= 0
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.stock is int
        && request.resource.data.stock >= 0
        && request.resource.data.minimumStockLevel is int
        && request.resource.data.minimumStockLevel >= 0
        && request.resource.data.criticalStockLevel is int
        && request.resource.data.criticalStockLevel >= 0
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name',
          'sku',
          'categoryId',
          'categoryName',
          'categoryAccent',
          'barcode',
          'costPrice',
          'price',
          'stock',
          'minimumStockLevel',
          'criticalStockLevel',
          'description',
          'isActive',
          'status',
          'updatedAt'
        ]);
    }

    function allowedSalesStockOut() {
      return canSellProducts()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['stock', 'updatedAt'])
        && request.resource.data.stock is int
        && request.resource.data.stock < resource.data.stock
        && request.resource.data.stock >= 0;
    }

    match /products/{productId} {
      allow read: if isActiveUser();
      allow create: if allowedProductCreate();
      allow update: if allowedProductOwnerUpdate() || allowedSalesStockOut();
      allow delete: if isActiveUser();
    }

    function canRegisterExpense() {
      return isActiveUser();
    }

    function allowedExpenseCreate() {
      return canRegisterExpense()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.status == 'approved'
        && request.resource.data.keys().hasOnly([
          'title',
          'amount',
          'note',
          'status',
          'createdBy',
          'createdByName',
          'createdAt'
        ]);
    }

    match /expenses/{expenseId} {
      allow read: if isActiveUser();
      allow create: if allowedExpenseCreate();
      allow update, delete: if isActiveUser();
    }

    function canSellProducts() {
      return isActiveUser();
    }

    function allowedSaleCreate() {
      return canSellProducts()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.productId is string
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && request.resource.data.unitPrice is number
        && request.resource.data.unitCost is number
        && request.resource.data.totalRevenue is number
        && request.resource.data.totalCost is number
        && request.resource.data.profit is number
        && request.resource.data.keys().hasOnly([
          'productId',
          'productName',
          'barcode',
          'quantity',
          'unitPrice',
          'unitCost',
          'totalRevenue',
          'totalCost',
          'profit',
          'createdBy',
          'createdByName',
          'createdAt'
        ]);
    }

    match /sales/{saleId} {
      allow read: if isActiveUser();
      allow create: if allowedSaleCreate();
      allow update, delete: if isActiveUser();
    }

    function canManagePurchases() {
      return isActiveUser();
    }

    function canManageCustomers() {
      return isActiveUser();
    }

    function canManageSuppliers() {
      return isActiveUser();
    }

    function canManageCredits() {
      return isActiveUser();
    }

    match /customers/{customerId} {
      allow read: if isActiveUser();
      allow create, update: if canManageCustomers()
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.totalPurchases is number
        && request.resource.data.keys().hasOnly([
          'name',
          'phone',
          'email',
          'totalPurchases',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if isActiveUser();
    }

    match /suppliers/{supplierId} {
      allow read: if isActiveUser();
      allow create, update: if canManageSuppliers()
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.outstandingBalance is number
        && request.resource.data.keys().hasOnly([
          'name',
          'phone',
          'email',
          'address',
          'productsSupplied',
          'outstandingBalance',
          'createdBy',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if isActiveUser();
    }

    match /credits/{creditId} {
      allow read: if isActiveUser();
      allow create, update: if canManageCredits()
        && request.resource.data.customerName is string
        && request.resource.data.phone is string
        && request.resource.data.amount is number
        && request.resource.data.paidAmount is number
        && request.resource.data.remainingBalance is number
        && request.resource.data.status in ['paid', 'partially_paid', 'unpaid']
        && request.resource.data.keys().hasOnly([
          'customerName',
          'phone',
          'productPurchased',
          'quantity',
          'amount',
          'paidAmount',
          'remainingBalance',
          'dueDate',
          'status',
          'createdBy',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if isActiveUser();
    }

    match /creditPayments/{paymentId} {
      allow read: if isActiveUser();
      allow create, update: if canManageCredits();
      allow delete: if isActiveUser();
    }

    match /purchases/{purchaseId} {
      allow read: if isActiveUser();
      allow create, update: if canManagePurchases()
        && request.resource.data.supplierName is string
        && request.resource.data.totalAmount is number
        && request.resource.data.paidAmount is number
        && request.resource.data.outstandingBalance is number
        && request.resource.data.keys().hasOnly([
          'supplierId',
          'supplierName',
          'totalAmount',
          'paidAmount',
          'outstandingBalance',
          'createdBy',
          'createdAt'
        ]);
      allow delete: if isActiveUser();
    }

    match /purchaseItems/{purchaseItemId} {
      allow read: if isActiveUser();
      allow create, update: if canManagePurchases();
      allow delete: if isAdmin();
    }

    match /saleItems/{saleItemId} {
      allow read: if isActiveUser();
      allow create: if canSellProducts()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.saleId is string
        && request.resource.data.productId is string
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && request.resource.data.unitPrice is number
        && request.resource.data.unitCost is number
        && request.resource.data.totalRevenue is number
        && request.resource.data.totalCost is number
        && request.resource.data.profit is number
        && request.resource.data.keys().hasOnly([
          'saleId',
          'productId',
          'productName',
          'barcode',
          'quantity',
          'unitPrice',
          'unitCost',
          'totalRevenue',
          'totalCost',
          'profit',
          'createdBy',
          'createdByName',
          'createdAt'
        ]);
      allow update: if isActiveUser();
      allow delete: if isActiveUser();
    }

    match /notifications/{notificationId} {
      allow read: if isActiveUser();
      allow update: if isActiveUser()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
      allow create, delete: if isActiveUser();
    }

    match /activityLogs/{activityLogId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role == userDoc(request.auth.uid).data.role
        && request.resource.data.keys().hasOnly([
          'userId',
          'userName',
          'role',
          'action',
          'deviceInfo',
          'createdAt'
        ]);
      allow update, delete: if isActiveUser();
    }

    match /settings/{settingId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser();
    }

    match /{document=**} {
      allow read, write: if isActiveUser();
    }
  }
}
